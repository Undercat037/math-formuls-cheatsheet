		{"id":"d233b13a33f7adf1","type":"text","text":"$\\sqrt[m]{\\sqrt[n]{a}} = \\sqrt[m \\cdot n]{a}$","x":2040,"y":-819,"width":250,"height":50,"color":"5"},
