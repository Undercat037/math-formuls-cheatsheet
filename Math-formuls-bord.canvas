		{"id":"4a42f27dcc258074","type":"text","text":"$x_1 + x_2 = -\\dfrac{b}{a}$","x":-960,"y":-925,"width":250,"height":60,"color":"5"},
		{"id":"810b95cc1ae6a4f6","type":"text","text":"$x_1 \\cdot x_2 = \\dfrac{c}{a}$","x":-960,"y":-865,"width":250,"height":60,"color":"5"},
