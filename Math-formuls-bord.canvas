		{"id":"3c8f73120576c756","type":"text","text":"$P(A) = \\dfrac{m}{n}$","x":6080,"y":-1088,"width":275,"height":60,"color":"5"},
		{"id":"e7b27e42293cb499","type":"text","text":"$0 \\leq P(A) \\leq 1$","x":6080,"y":-1028,"width":275,"height":60,"color":"5"},
		{"id":"ece1533f78b44dcf","type":"text","text":"$P(A) + P(\\bar{A}) = 1$","x":6080,"y":-968,"width":275,"height":60,"color":"5"},
		{"id":"889346c44619fc25","type":"text","text":"$P(A+B) = P(A) + P(B) - P(AB)$","x":6080,"y":-909,"width":275,"height":60,"color":"5"},
		{"id":"60941767d530d6fc","type":"text","text":"$P(AB) = P(A) \\cdot P(B)$","x":6080,"y":-849,"width":275,"height":60,"color":"5"},
		{"id":"d701e7b970b617e5","type":"text","text":"Арифметична прогресія","x":6498,"y":-1064,"width":250,"height":60},
		{"id":"be2484f99b696e4e","type":"text","text":"$a_n = a_1 + (n-1)d$","x":6660,"y":-908,"width":250,"height":60,"color":"5"},
		{"id":"69c121ca33edaa81","type":"text","text":"$S_n = \\dfrac{2a_1 + (n-1)d}{2} \\cdot n$","x":6660,"y":-788,"width":250,"height":60,"color":"5"},
		{"id":"ccaf0d64be96111c","type":"text","text":"Геометрична прогресія","x":7020,"y":-1064,"width":250,"height":60},
		{"id":"5600aed7a5561351","type":"text","text":"$b_n = b_1 \\cdot q^{n-1}$","x":7200,"y":-908,"width":250,"height":60,"color":"5"},
		{"id":"ebb14e972cf18506","type":"text","text":"$S_n = \\dfrac{b_1(q^n - 1)}{q - 1}$","x":7200,"y":-848,"width":250,"height":60,"color":"5"},
		{"id":"bcf2b68711aca489","type":"text","text":"$S = \\dfrac{b_1}{1 - q}, \\quad |q| < 1$","x":7200,"y":-788,"width":250,"height":60,"color":"5"},
		{"id":"00d48f5495a940af","type":"text","text":"$S_n = \\dfrac{(a_1 + a_n) \\cdot n}{2}$","x":6660,"y":-848,"width":250,"height":60,"color":"5"},
