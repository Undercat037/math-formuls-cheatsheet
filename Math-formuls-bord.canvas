		{"id":"24092065d606a730","type":"text","text":"$\\sin(\\alpha + \\beta) = \\sin\\alpha\\cos\\beta + \\cos\\alpha\\sin\\beta$","x":1269,"y":-922,"width":370,"height":50,"color":"5"},
		{"id":"126370de7ee524d6","type":"text","text":"$\\sin(\\alpha - \\beta) = \\sin\\alpha\\cos\\beta - \\cos\\alpha\\sin\\beta$","x":1269,"y":-872,"width":370,"height":53,"color":"5"},
		{"id":"393573d7560d55d0","type":"text","text":"$\\cos(\\alpha + \\beta) = \\cos\\alpha\\cos\\beta - \\sin\\alpha\\sin\\beta$","x":1269,"y":-820,"width":370,"height":50,"color":"5"},
		{"id":"4505b026585e3307","type":"text","text":"$\\cos(\\alpha - \\beta) = \\cos\\alpha\\cos\\beta + \\sin\\alpha\\sin\\beta$","x":1269,"y":-773,"width":370,"height":50,"color":"5"},
		{"id":"e4c4e0f2a261f7c5","type":"text","text":"**Формули додавання аргументів**","x":1040,"y":-1206,"width":250,"height":60,"color":"2"},
		{"id":"be7ea3fb1d57c95e","type":"text","text":"$(\\text{tg}\\, x)'$ = $\\dfrac{1}{\\cos^2 x}$","x":5410,"y":-854,"width":280,"height":59,"color":"5"},
		{"id":"ea815c327729b07c","type":"text","text":"$(\\text{ctg}\\, x)'$ = $-\\dfrac{1}{\\sin^2 x}$","x":5410,"y":-795,"width":280,"height":60,"color":"5"},
		{"id":"60a0989d2702d33e","type":"text","text":"$\\left(\\dfrac{u}{v}\\right)'$ = $\\dfrac{u'v - uv'}{v^2}$","x":5410,"y":-735,"width":280,"height":60,"color":"5"},
		{"id":"e9c99f7ac01a207c","type":"text","text":"$(uv)' = u'v + uv'$","x":5410,"y":-675,"width":280,"height":50,"color":"5"},
		{"id":"6711439e4d94bb96","type":"text","text":"$(f(g(x)))' = f'(g(x)) \\cdot g'(x)$","x":5410,"y":-625,"width":280,"height":60,"color":"5"},
		{"id":"614fe70bc918bb12","type":"text","text":"**Похідні**","x":5160,"y":-1206,"width":250,"height":60,"color":"2"},
		{"id":"19f1b76ff73e064a","type":"text","text":"$(x^n)'$  = $nx^{n-1}$","x":5410,"y":-1103,"width":280,"height":50,"color":"5"},
		{"id":"52bc93a7744e2b04","type":"text","text":"$(c)'$ = 0","x":5410,"y":-1053,"width":280,"height":50,"color":"5"},
		{"id":"32c27cc4334408fd","type":"text","text":"$(\\cos x)'$ = $-\\sin x$","x":5410,"y":-904,"width":280,"height":50,"color":"5"},
		{"id":"7ecda3754c4a6707","type":"text","text":"$x'$ = 1","x":5410,"y":-1003,"width":280,"height":50,"color":"5"},
		{"id":"10ba63c7449b5880","type":"text","text":"$(\\sin x)'$ = $\\cos x$","x":5410,"y":-955,"width":280,"height":51,"color":"5"},
		{"id":"bd444316b16a857c","type":"text","text":"# Root","x":-3360,"y":-240,"width":250,"height":130,"color":"#ff0000"},
		{"id":"6860d4e68cc5abb9","type":"text","text":"$(c \\cdot u)' = c \\cdot u'$","x":5410,"y":-209,"width":280,"height":60,"color":"5"},
		{"id":"0aae7e7ea6ea9147","type":"text","text":"$(u \\pm v)' = u' \\pm v'$","x":5410,"y":-150,"width":280,"height":60,"color":"5"},
		{"id":"e13c98f1e0f40990","type":"text","text":"$(|u|)' = \\dfrac{u' \\cdot u}{|u|}$","x":5410,"y":-90,"width":280,"height":60,"color":"5"},
		{"id":"508e5815911a5dc5","type":"text","text":"$(\\ln x)' = \\dfrac{1}{x}$","x":5410,"y":-515,"width":280,"height":60,"color":"5"},
		{"id":"96dbd0e2345910a3","type":"text","text":"$(\\sqrt{x})' = \\dfrac{1}{2\\sqrt{x}}$","x":5410,"y":-392,"width":280,"height":63,"color":"5"},
		{"id":"9b488bf6bccf1b09","type":"text","text":"$(a^x)' = a^x \\ln a$","x":5410,"y":-329,"width":280,"height":60,"color":"5"},
		{"id":"6cbc259622ec6e45","type":"text","text":"\n$(log_a x)' = \\dfrac{1}{x \\ln a}$","x":5410,"y":-269,"width":280,"height":60,"color":"5"},
		{"id":"2fe481146fd69789","type":"text","text":"$(\\sqrt{u})' = \\dfrac{u'}{2\\sqrt{u}}$","x":5410,"y":-455,"width":280,"height":63,"color":"5"},
		{"id":"df7649524594f47c","type":"text","text":"$(e^x)' = e^x$","x":5410,"y":-565,"width":280,"height":50,"color":"5"},
